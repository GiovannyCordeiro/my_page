<%= stylesheet_link_tag 'shared/anotations' %>


<% @annotations.each do |annotation| %>  
  <div class="anotation">
    <h2>
      <%= link_to annotation.title, "/my_annotations/#{annotation.title}"%>
    </h2>
    <p>
      <%= annotation.created_at.strftime('%d/%m/%Y') %>
    </p>
    <div class="container-tags">
      <!--procurando id tac-->
      <% registry_tags = TagAnnotation.select('tags.id', 'tags.content').joins(:tag).where(annotation_id: annotation.id) %>
        <!--percorrendo todas as tags-->
        <% registry_tags.each do |tag| %>
        <!--vinculando com o tabela que da o nome-->
        <%= render  "shared/tag", tag: "#{tag.content}"%>
      <% end %>
    </div>
    <span>
      <%= annotation.description %>
    </span>
  </div>
<% end %>
